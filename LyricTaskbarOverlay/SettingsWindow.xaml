<Window x:Class="LyricTaskbarOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Lyric Overlay" Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Appearance" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Bg Opacity:" Width="100" VerticalAlignment="Center"/>
            <Slider x:Name="OpacitySlider" Width="150" Minimum="0.0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnSettingChanged"/>
            <TextBlock x:Name="OpacityValueText" Text="100%" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Font Size:" Width="100" VerticalAlignment="Center"/>
            <Slider x:Name="FontSizeSlider" Width="150" Minimum="10" Maximum="36" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnSettingChanged"/>
            <TextBlock x:Name="FontSizeValueText" Text="15 px" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Active Color:" Width="100" VerticalAlignment="Center"/>
            <Button x:Name="ActiveColorBtn" Width="100" Height="22" Click="ColorBtn_Click">
                <Rectangle x:Name="ActiveColorRect" Width="80" Height="14" Fill="White" />
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Next Color:" Width="100" VerticalAlignment="Center"/>
            <Button x:Name="InactiveColorBtn" Width="100" Height="22" Click="ColorBtn_Click">
                <Rectangle x:Name="InactiveColorRect" Width="80" Height="14" Fill="Gray" />
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Sync Offset:" Width="100" VerticalAlignment="Center"/>
            <Slider x:Name="OffsetSlider" Width="150" Minimum="-5000" Maximum="5000" TickFrequency="100" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnSettingChanged"/>
            <TextBlock x:Name="OffsetValueText" Text="2500 ms" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="Behavior" FontWeight="Bold" FontSize="16" Margin="0,15,0,10"/>

        <CheckBox x:Name="PinCheckBox" Grid.Row="7" Content="Pin to screen (disable dragging)" Margin="0,5" Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
        
        <CheckBox x:Name="StartupCheckBox" Grid.Row="8" Content="Run on Windows Startup" Margin="0,5" Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

        <Button Grid.Row="10" Content="Close" Width="80" HorizontalAlignment="Right" Click="CloseButton_Click"/>
    </Grid>
</Window>
